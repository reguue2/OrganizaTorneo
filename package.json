{
  "name": "organiza-torneo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "security:secrets": "gitleaks detect --source . --redact --no-banner",
    "security:secrets:staged": "gitleaks protect --staged --redact --no-banner",
    "db:types": "mkdir -p .tmp/supabase-home && HOME=$PWD/.tmp/supabase-home supabase gen types typescript --local > .tmp/database.types.ts && mv .tmp/database.types.ts src/types/database.ts",
    "arch:check": "depcruise src --config dependency-cruiser.config.cjs",
    "knip": "knip --exclude binaries --no-config-hints",
    "lefthook:install": "lefthook install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.1",
    "shadcn": "^4.8.2",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rolldown/binding-linux-x64-gnu": "^1.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.1.1",
    "knip": "^5.88.1",
    "lefthook": "^2.1.9",
    "supabase": "^2.104.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
